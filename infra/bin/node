#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_BIN="$SCRIPT_DIR/../node/node-v22.22.2-linux-x64/bin/node"

if [[ ! -x "$NODE_BIN" ]]; then
  echo "MediaCreator Node.js 22 toolchain is missing. Run 'make install' first." >&2
  exit 1
fi

exec "$NODE_BIN" "$@"
