# MediaCreator bootstrap environment
MEDIACREATOR_APP_NAME=MediaCreator

# Web and API ports
MEDIACREATOR_WEB_HOST=127.0.0.1
MEDIACREATOR_WEB_PORT=3000
MEDIACREATOR_API_HOST=127.0.0.1
MEDIACREATOR_API_PORT=8010
NEXT_PUBLIC_MEDIACREATOR_API_BASE_URL=http://127.0.0.1:8010

# PostgreSQL 16 local runtime
MEDIACREATOR_DB_HOST=127.0.0.1
MEDIACREATOR_DB_PORT=54329
MEDIACREATOR_DB_NAME=mediacreator
MEDIACREATOR_DB_USER=mediacreator
MEDIACREATOR_DB_PASSWORD=mediacreator
MEDIACREATOR_DATABASE_URL=postgresql+psycopg://mediacreator:mediacreator@127.0.0.1:54329/mediacreator

# Storage and tool placeholders for later phases
MEDIACREATOR_STORAGE_SCRATCH_ROOT=/var/tmp/mediacreator/scratch
MEDIACREATOR_STORAGE_NAS_ROOT=/mnt/nas/mediacreator
MEDIACREATOR_STORAGE_MODELS_ROOT=/mnt/nas/mediacreator/models
MEDIACREATOR_STORAGE_LORAS_ROOT=/mnt/nas/mediacreator/models/loras
MEDIACREATOR_STORAGE_CHECKPOINTS_ROOT=/mnt/nas/mediacreator/models/checkpoints
MEDIACREATOR_STORAGE_EMBEDDINGS_ROOT=/mnt/nas/mediacreator/models/embeddings
MEDIACREATOR_STORAGE_VAES_ROOT=/mnt/nas/mediacreator/models/vaes
MEDIACREATOR_STORAGE_UPLOADED_PHOTOS_ROOT=/mnt/nas/mediacreator/photos/uploaded
MEDIACREATOR_STORAGE_PREPARED_IMAGES_ROOT=/mnt/nas/mediacreator/photos/prepared
MEDIACREATOR_STORAGE_CHARACTER_ASSETS_ROOT=/mnt/nas/mediacreator/characters
MEDIACREATOR_STORAGE_WARDROBE_ROOT=/mnt/nas/mediacreator/wardrobe
MEDIACREATOR_STORAGE_EXPORTS_ROOT=/mnt/nas/mediacreator/exports
MEDIACREATOR_STORAGE_RENDERS_ROOT=/mnt/nas/mediacreator/renders
MEDIACREATOR_COMFYUI_ROOT=/opt/comfyui
MEDIACREATOR_COMFYUI_BASE_URL=http://127.0.0.1:8188
MEDIACREATOR_COMFYUI_WORKFLOWS_ROOT=/opt/MediaCreator/workflows/comfyui
MEDIACREATOR_BLENDER_BIN=/opt/blender-4.5-lts/blender
MEDIACREATOR_WORKER_CONCURRENCY=1
